<?xml version="1.0"?>
<component name="org.nuxeo.audit.opensearch1.contrib">

  <extension target="org.nuxeo.runtime.opensearch1.OpenSearchComponent" point="client">
    <client id="audit/default">
<#if "${(nuxeo.opensearch1.embed.enabled)!}" == "true" && "${nuxeo.audit.backend.default.opensearch1.client.server}" == "">
      <embedServer>${nuxeo.opensearch1.embed.name}</embedServer>
<#else>
      <server>${nuxeo.audit.backend.default.opensearch1.client.server}</server>
</#if>
      <connectionTimeout>${nuxeo.audit.backend.default.opensearch1.client.connectionTimeout}</connectionTimeout>
      <socketTimeout>${nuxeo.audit.backend.default.opensearch1.client.socketTimeout}</socketTimeout>
      <sslCertificateVerification>${nuxeo.audit.backend.default.opensearch1.client.sslCertificateVerification}</sslCertificateVerification>
      <username>${nuxeo.audit.backend.default.opensearch1.client.username}</username>
      <password>${nuxeo.audit.backend.default.opensearch1.client.password}</password>
      <trustStore type="${nuxeo.audit.backend.default.opensearch1.client.trustStore.type}">
        <path>${nuxeo.audit.backend.default.opensearch1.client.trustStore.path}</path>
        <password>${nuxeo.audit.backend.default.opensearch1.client.trustStore.password}</password>
      </trustStore>
      <keyStore type="${nuxeo.audit.backend.default.opensearch1.client.keyStore.type}">
        <path>${nuxeo.audit.backend.default.opensearch1.client.keyStore.path}</path>
        <password>${nuxeo.audit.backend.default.opensearch1.client.keyStore.password}</password>
      </keyStore>
    </client>
  </extension>

  <require>org.nuxeo.audit.opensearch1.backend.contrib</require>
  <extension target="org.nuxeo.runtime.opensearch1.OpenSearchComponent" point="index">
    <index name="${nuxeo.audit.backend.default.opensearch1.index.name}">
      <client id="audit/default" />
      <mapping file="opensearch1-audit-mapping.json" />
      <settings file="opensearch1-audit-settings.json" />
    </index>
  </extension>

</component>
