<?xml version="1.0"?>
<component name="org.nuxeo.duo.factors.login.contrib">

  <require>org.nuxeo.ecm.platform.ui.web.auth.WebEngineConfig</require>

  <documentation>
    This authentication plugin processes DuoWeb Two Factors Authentication
  </documentation>

  <extension
          target="org.nuxeo.ecm.platform.ui.web.auth.service.PluggableAuthenticationService"
          point="authenticators">
    <authenticationPlugin name="DUO_TWO_FACTORS_AUTH"
                          enabled="true"
                          class="org.nuxeo.duoweb.authentication.DuoFactorsAuthenticator">
      <needStartingURLSaving>true</needStartingURLSaving>
      <loginModulePlugin>Trusting_LM</loginModulePlugin>
      <parameters>
        <parameter name="IKEY">${nuxeo.duoweb.clientId}</parameter>
        <parameter name="SKEY">${nuxeo.duoweb.clientSecret}</parameter>
        <parameter name="HOST">${nuxeo.duoweb.host}</parameter>
        <parameter name="appUrl">${nuxeo.url}</parameter>
        <parameter name="skipHealthCheck">${nuxeo.duoweb.skipHealthCheck}</parameter>
        <parameter name="proxyHost">${nuxeo.duoweb.proxyHost}</parameter>
        <parameter name="proxyPort">${nuxeo.duoweb.proxyPort}</parameter>
        <parameter name="userAgentInfo">${nuxeo.duoweb.userAgentInfo}</parameter>
        <parameter name="caCerts">${nuxeo.duoweb.caCerts}</parameter>
      </parameters>
    </authenticationPlugin>
  </extension>

  <extension
          target="org.nuxeo.ecm.platform.ui.web.auth.service.PluggableAuthenticationService"
          point="chain">
    <authenticationChain>
      <plugins>
        <plugin>BASIC_AUTH</plugin>
        <plugin>TOKEN_AUTH</plugin>
        <plugin>OAUTH2_AUTH</plugin>
        <plugin>JWT_AUTH</plugin>
        <plugin>DUO_TWO_FACTORS_AUTH</plugin>
        <plugin>WEBENGINE_FORM_AUTH</plugin>
        <plugin>ANONYMOUS_AUTH</plugin>
      </plugins>
    </authenticationChain>
  </extension>

</component>
