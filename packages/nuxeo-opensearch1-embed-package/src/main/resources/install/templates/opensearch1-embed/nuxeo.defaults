## DO NOT EDIT THIS FILE, USE nuxeo.conf  ##
nuxeo.template.includes=common
opensearch1-embed.target=.

# mandatory
nuxeo.opensearch1.embed.name=${elasticsearch.clusterName:=embeddedOpenSearch1}

# optional
nuxeo.opensearch1.embed.enabled=true
nuxeo.opensearch1.embed.nodeName=${elasticsearch.nodeName:=openSearch1Node}
nuxeo.opensearch1.embed.dataPath=
nuxeo.opensearch1.embed.homePath=
nuxeo.opensearch1.embed.http.port=9200-9300
