persistence:
  enabled: true
resources:
  requests:
    cpu: "15"
    memory: "56Gi"
  limits:
    memory: "56Gi"
opensearchJavaOpts: "-Xmx32g -Xms32g"
podAnnotations:
  ad.datadoghq.com/elasticsearch.checks: |
    {
      "elastic": {
        "init_config": {},
        "instances": [
          {
            "url": "http://%%host%%:9200"
          }
        ]
      }
    }
  ad.datadoghq.com/tags: '{"service":"{{ env "SERVICE_TAG" | default "benchmark-local" }}"}'
