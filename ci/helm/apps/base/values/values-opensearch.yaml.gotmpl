image:
  tag: 1.3.19
clusterName: opensearch
replicas: 1
singleNode: true
persistence:
  enabled: false
resources:
  requests:
    cpu: "500m"
    memory: "2Gi"
  limits:
    memory: "2Gi"
opensearchJavaOpts: "-Xmx1g -Xms1g"
config:
  opensearch.yml:
    plugins:
      security:
        disabled: true
labels: {{- toYaml .Values.global.labels | nindent 2 }}
  dev.nuxeo.com/app: opensearch
  dev.nuxeo.com/resource: pod
service:
  labels: {{- toYaml .Values.global.labels | nindent 4 }}
    dev.nuxeo.com/app: opensearch
    dev.nuxeo.com/resource: service
maxUnavailable: 0
{{- toYaml .Values.global.selectors | nindent 0 }}
