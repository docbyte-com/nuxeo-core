clusterName: elasticsearch
replicas: 1
persistence:
  enabled: false
minimumMasterNodes: 1
maxUnavailable: null
resources:
  requests:
    cpu: "500m"
    memory: "1024Mi"
  limits:
    memory: "1024Mi"
esJavaOpts: "-Xmx380m -Xms380m"
labels: {{- toYaml .Values.global.labels | nindent 2 }}
  dev.nuxeo.com/app: elasticsearch
  dev.nuxeo.com/resource: pod
service:
  labels: {{- toYaml .Values.global.labels | nindent 4 }}
    dev.nuxeo.com/app: elasticsearch
    dev.nuxeo.com/resource: service
{{- toYaml .Values.global.selectors | nindent 0 }}
