<?xml version="1.0"?>
<component name="org.nuxeo.transientstore.TransientStorageComponent.testContrib">

  <extension target="org.nuxeo.ecm.core.transientstore.TransientStorageComponent" point="store">

    <store name="default" class="org.nuxeo.ecm.core.transientstore.SimpleTransientStore">
    </store>

    <store name="testStore" class="org.nuxeo.ecm.core.transientstore.SimpleTransientStore">
    </store>

    <store name="microStore" class="org.nuxeo.ecm.core.transientstore.SimpleTransientStore">
      <!-- a store that can not store anything -->
      <targetMaxSize>0</targetMaxSize>
      <absoluteMaxSize>0</absoluteMaxSize>
    </store>

    <store name="miniStore" class="org.nuxeo.ecm.core.transientstore.SimpleTransientStore">
      <!-- a store that deletes entries as soon as they are no longer needed -->
      <targetMaxSize>0</targetMaxSize>
      <absoluteMaxSize>1MiB</absoluteMaxSize>
    </store>

  </extension>

</component>
