<?xml version="1.0"?>
<component name="org.nuxeo.ecm.core.convert.cache.test.default">
  <require>org.nuxeo.ecm.core.convert.cache</require>

  <extension target="org.nuxeo.ecm.core.convert.service.ConversionServiceImpl" point="configuration">
    <!-- enable the cache for tests but configure the GC to not run during tests -->
    <cache enabled="true">
      <gcRate>2h</gcRate>
    </cache>
  </extension>

</component>
