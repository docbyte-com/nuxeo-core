<?xml version="1.0"?>
<component name="org.nuxeo.ecm.core.test.repository">

  <require>org.nuxeo.runtime.datasource.test</require>
  <extension target="org.nuxeo.runtime.datasource" point="datasources">
    <link name="jdbc/repository_test" global="jdbc/${nuxeo.test.sql.database}"/>
  </extension>

  <extension target="org.nuxeo.ecm.core.storage.sql.RepositoryService" point="repository">
    <repository name="test">
      <idType>${nuxeo.test.vcs.idtype}</idType>
      <changeTokenEnabled>${nuxeo.test.changetoken.enabled}</changeTokenEnabled>
      <schema>
        <field type="largetext">note</field>
        <field type="largetext">relatedtext</field>
      </schema>
      <indexing>
        <neverPerDocumentFacets>
          <facet>NotPerDocFacet</facet>
        </neverPerDocumentFacets>
        <fulltext catalog="nuxeo" analyzer="French"
                  disabled="${nuxeo.test.fulltext.disabled}"
                  storedInBlob="${nuxeo.test.fulltext.storedInBlob}"
                  searchDisabled="${nuxeo.test.fulltext.search.disabled}"/>
      </indexing>
      <xa-datasource>com.microsoft.sqlserver.jdbc.SQLServerXADataSource</xa-datasource>
      <property name="ServerName">${nuxeo.test.sql.server}</property>
      <property name="PortNumber">${nuxeo.test.sql.port}</property>
      <property name="DatabaseName">${nuxeo.test.sql.database}</property>
      <property name="User">${nuxeo.test.sql.user}</property>
      <property name="Password">${nuxeo.test.sql.password}</property>
      <property name="UseCursors">true</property>
    </repository>
  </extension>

</component>
