<?xml version="1.0"?>
<component name="org.nuxeo.ecm.core.search.client.opensearch1.test.dynamic-mapping">
  <require>org.nuxeo.ecm.core.search.opensearch1.test</require>
  <extension target="org.nuxeo.runtime.opensearch1.OpenSearchComponent" point="index">
    <index name="nxutest">
      <mapping file="OSGI-INF/search/test-opensearch1-dynamic-mapping.json" append="true"/>
    </index>
  </extension>
  <!-- custom writer to be used with the dynamic mapper -->
  <extension target="org.nuxeo.ecm.core.search" point="searchIndex">
    <searchIndex name="enhanced"
                 writerClass="org.nuxeo.ecm.core.search.client.opensearch1.CustomOpensearch1IndexingJsonWriter" />
  </extension>
</component>
