<?xml version="1.0"?>
<component name="org.nuxeo.ecm.core.search.reindexVersions.listener" version="1.0">

    <extension target="org.nuxeo.ecm.core.bulk" point="actions">
        <action name="reindexVersions" inputStream="bulk/reindexVersions" bucketSize="100" batchSize="50" />
    </extension>

    <extension target="org.nuxeo.runtime.stream.service" point="streamProcessor">
        <streamProcessor name="reindexVersions" class="org.nuxeo.ecm.core.search.versioning.ReindexVersionsAction"
                         defaultConcurrency="${nuxeo.bulk.action.reindexVersions.defaultConcurrency:=2}"
                         defaultPartitions="${nuxeo.bulk.action.reindexVersions.defaultPartitions:=4}">
            <policy name="default" maxRetries="2" delay="1s" maxDelay="10s" continueOnFailure="true"/>
        </streamProcessor>
    </extension>

    <extension target="org.nuxeo.ecm.core.event.EventServiceComponent" point="listener">
        <listener name="liveDocumentMovedListener" async="false" postCommit="false"
                  enabled="${nuxeo.search.reindexVersionsListener.enabled:=false}"
                  class="org.nuxeo.ecm.core.search.versioning.ReindexVersionsOnMoveListener">
            <event>documentMoved</event>
        </listener>
    </extension>

</component>
