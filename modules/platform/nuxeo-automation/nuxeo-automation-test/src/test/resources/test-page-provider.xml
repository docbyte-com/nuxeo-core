<component name="org.nuxeo.ecm.automation.provider.test" version="1.0">

  <require>org.nuxeo.ecm.core.CoreExtensions</require>

  <extension target="org.nuxeo.ecm.platform.query.api.PageProviderService" point="providers">

    <coreQueryPageProvider name="NXQLPageProvider">
      <pattern quoteParameters="false" escapeParameters="false">?</pattern>
    </coreQueryPageProvider>

    <coreQueryPageProvider name="PageProvider">
      <pattern>
        SELECT * FROM Document
      </pattern>
      <sort column="dc:title" ascending="true"/>
      <pageSize>2</pageSize>
      <quickFilters>
        <quickFilter name="SectionRoot">
          <clause>ecm:primaryType = 'SectionRoot'</clause>
        </quickFilter>
        <quickFilter name="FileOnly">
          <clause>ecm:primaryType = 'File'</clause>
        </quickFilter>
      </quickFilters>
    </coreQueryPageProvider>

    <coreQueryPageProvider name="QuickFilterPageProvider">
      <whereClause>
        <fixedPart>
          ecm:mixinType != 'HiddenInNavigation'
        </fixedPart>
      </whereClause>
      <sort column="dc:title" ascending="true"/>
      <pageSize>2</pageSize>
      <quickFilters>
        <quickFilter name="FileOnly">
          <clause>ecm:primaryType = 'File'</clause>
        </quickFilter>
      </quickFilters>
    </coreQueryPageProvider>

    <searchServicePageProvider name="SEARCH_ALL_REPOSITORIES_PP">
      <property name="searchAllRepositories">true</property>
      <pattern>SELECT * FROM Document
        WHERE ecm:path = ?
        AND ecm:isVersion = 0
        AND ecm:mixinType != 'HiddenInNavigation'
        AND ecm:isTrashed = 0
      </pattern>
      <sort ascending="true" column="dc:title" />
    </searchServicePageProvider>

  </extension>

</component>
