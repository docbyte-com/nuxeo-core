@startuml
title Audit Router Introspection

hide members

skinparam defaultFontName Courier
skinparam handwritten false
skinparam queue {
  BackgroundColor LightYellow
}
skinparam node {
  BackgroundColor White
}
skinparam component {
  BackgroundColor Azure
  BorderColor black
  ArrowColor #CC6655
}
component event_listener [
Event Listener
----
events:
- loginSuccess
- loginFailed
- logout
- documentCreated
- documentCreatedByCopy
- documentDuplicated
- documentMoved
- documentRemoved
- documentModified
- documentLocked
- documentUnlocked
- documentSecurityUpdated
- lifecycle_transition_event
- documentCheckedIn
- proxyRemoved
- versionRemoved
- documentProxyPublished
- sectionContentPublished
- documentRestored
- download
- documentTrashed
- documentUntrashed
- addedToCollection
- removedFromCollection
- blobDigestUpdated
- retentionActiveChanged
- afterMakeRecord
- afterSetRetention
- afterExtendRetention
- retentionExpired
- afterSetLegalHold
- afterRemoveLegalHold
- user_created
- user_deleted
- user_modified
- group_created
- group_deleted
- group_modified
- search
]
queue stream_audit_audit as "audit/audit" {
  component computation_audit_writer [
  audit/writer
  ]
}
event_listener==>stream_audit_audit
stream_audit_audit=[hidden]=>stream_audit_audit.computation_audit_writer
package audit_router as "Audit Router" {
  component route_default [
  default
  ]
}
package audit_backend as "Audit Backends" {
  database backend_default as "default" {
    class implementation as "${defaultBackendImplementation}" {
    }
  }
  backend_default=[hidden]=>backend_default.implementation
  database backend_other as "other" {
    class implementation as "org.nuxeo.audit.mem.MemAuditBackend" {
    }
  }
  backend_other=[hidden]=>backend_other.implementation
}
stream_audit_audit.computation_audit_writer==>audit_router
audit_router==>audit_router.route_default
audit_router.route_default==>audit_backend.backend_default
@enduml
