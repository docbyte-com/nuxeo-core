    <register class="org.nuxeo.ecm.restapi.server.enrichers.AuditJsonEnricher"
              enable="true" />
    <register class="org.nuxeo.ecm.restapi.server.enrichers.HasContentJsonEnricher"
              enable="true" />
    <register class="org.nuxeo.ecm.core.io.marshallers.json.enrichers.HasFolderishChildJsonEnricher"
              enable="false" />
