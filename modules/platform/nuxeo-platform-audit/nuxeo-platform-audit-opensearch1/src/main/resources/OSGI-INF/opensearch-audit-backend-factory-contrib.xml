<?xml version="1.0"?>
<component name="org.nuxeo.audit.opensearch1.backend.contrib">
  <!-- Alias is deprecated since 2025.0 -->
  <alias>org.nuxeo.elasticsearch.audit.contrib</alias>

  <extension target="org.nuxeo.runtime.opensearch1.OpenSearchComponent" point="index">
    <index name="${nuxeo.audit.backend.default.opensearch1.index.name:=audit}">
      <client id="audit/default" />
      <mapping>
      {
        "dynamic_templates": [
          {
            "strings": {
              "match_mapping_type": "string",
              "mapping": {
                "type": "keyword",
                "copy_to": "all_field",
                "ignore_above": 256
              }
            }
          }
        ],
        "properties": {
          "all_field": {
            "type": "text",
            "analyzer": "fulltext"
          },
          "docPath": {
            "type": "keyword",
            "fields": {
              "children": {
                "type": "text",
                "analyzer": "path_analyzer"
              }
            }
          },
          "logDate": {
            "type": "date"
          },
          "eventDate": {
            "type": "date"
          },
          "comment": {
            "type": "text",
            "copy_to": "all_field",
            "fields": {
              "fulltext": {
                "analyzer": "fulltext",
                "type": "text"
              }
            }
          },
          "id": {
            "type": "long"
          },
          "extended.params": {
            "type": "object",
            "enabled": false
          }
        }
      }
      </mapping>
    </index>
  </extension>

  <extension target="org.nuxeo.audit.opensearch1.OpenSearchAuditBackendFactory" point="backend">
    <backend name="default" enabled="${nuxeo.audit.backend.default.opensearch1.enabled:=true}"
             clientId="audit/default"  indexName="${nuxeo.audit.backend.default.opensearch1.index.name:=audit}" />
  </extension>

</component>
