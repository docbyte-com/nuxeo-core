<?xml version="1.0"?>
<component name="org.nuxeo.audit.elasticsearch.contrib">
  <!-- Alias is deprecated since 2025.0 -->
  <alias>org.nuxeo.elasticsearch.audit.contrib</alias>

  <require>org.nuxeo.ecm.platform.audit.service.NXAuditEventsService</require>

  <extension target="org.nuxeo.ecm.platform.audit.service.NXAuditEventsService" point="backend">
    <backend class="org.nuxeo.audit.elasticsearch.ESAuditBackend">
      <require>org.nuxeo.elasticsearch.ElasticSearchComponent</require>
    </backend>
  </extension>

  <extension target="org.nuxeo.ecm.platform.audit.service.NXAuditEventsService" point="storage">
    <storage id="elasticsearchAuditStorage" class="org.nuxeo.audit.elasticsearch.ESAuditBackend"/>
  </extension>

</component>
