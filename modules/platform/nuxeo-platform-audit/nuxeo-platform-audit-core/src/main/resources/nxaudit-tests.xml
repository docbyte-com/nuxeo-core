<component name="org.nuxeo.audit.tests.config">
  <!-- Alias is deprecated since 2025.0 -->
  <alias>org.nuxeo.ecm.platform.audit.tests.config</alias>

  <extension target="org.nuxeo.ecm.core.persistence.PersistenceComponent"
    point="hibernate">
    <hibernateConfiguration name="nxaudit-logs">
      <properties>
            <property name="hibernate.connection.url">jdbc:h2:mem:;MODE=LEGACY</property>;
            <property name="hibernate.connection.driver_class">org.h2.Driver</property>
            <property name="hibernate.connection.auto_commit">true</property>
          <property name="hibernate.connection.pool_size">1</property>;
          <property name="hibernate.dialect">org.hibernate.dialect.H2Dialect</property>;
          <property name="hibernate.hbm2ddl.auto">create-drop</property>;
          <property name="hibernate.show_sql">false</property>; // true to debug
          <property name="hibernate.format_sql">true</property>;
       </properties>
    </hibernateConfiguration>
  </extension>

</component>
