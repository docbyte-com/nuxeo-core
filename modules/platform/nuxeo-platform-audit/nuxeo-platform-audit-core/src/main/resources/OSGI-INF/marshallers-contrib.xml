    <register class="org.nuxeo.audit.io.LogEntryJsonWriter" enable="true" />
    <register class="org.nuxeo.audit.io.LogEntryListJsonWriter" enable="true" />
    <register class="org.nuxeo.audit.io.LogEntryCSVWriter" enable="true" />
