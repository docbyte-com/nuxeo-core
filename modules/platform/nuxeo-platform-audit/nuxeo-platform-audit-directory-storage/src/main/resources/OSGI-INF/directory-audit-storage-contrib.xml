<?xml version="1.0"?>
<component name="org.nuxeo.audit.directory.storage">
  <!-- Alias is deprecated since 2025.0 -->
  <alias>org.nuxeo.audit.storage.directory</alias>

  <require>org.nuxeo.ecm.platform.audit.service.NXAuditEventsService</require>

  <extension target="org.nuxeo.ecm.platform.audit.service.NXAuditEventsService" point="storage">
    <storage id="DirectoryAuditStorage" class="org.nuxeo.audit.directory.storage.DirectoryAuditStorage" />
  </extension>

  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="schema">
    <schema name="audit" src="schemas/audit.xsd" />
  </extension>

  <extension target="org.nuxeo.ecm.directory.GenericDirectory" point="directories">
    <directory name="auditStorage" extends="template-directory">
      <schema>audit</schema>
      <idField>id</idField>
      <autoincrementIdField>true</autoincrementIdField>
      <substringMatchType>subany</substringMatchType>
    </directory>
  </extension>
</component>
