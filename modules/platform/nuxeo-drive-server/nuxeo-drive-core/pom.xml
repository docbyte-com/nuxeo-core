  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <executions>
          <execution>
            <configuration>
              <archive>
                <manifestFile>
                  src/test/resources/META-INF/MANIFEST.MF
                </manifestFile>
              </archive>
            </configuration>
            <goals>
              <goal>test-jar</goal>
            </goals>
          </execution>
        </executions>
      </plugin>
    </plugins>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-dependency-plugin</artifactId>
          <configuration>
            <ignoredUnusedDeclaredDependencies combine.children="append">
              <!-- dependencies wrongly detected by the plugin -->
              <!-- no occurrences in java code but deploy by Nuxeo runtime -->
              <artifact>org.nuxeo.ecm.automation:nuxeo-automation-core</artifact>
              <artifact>org.nuxeo.ecm.platform:nuxeo-platform-directory-api</artifact>
              <artifact>org.nuxeo.ecm.platform:nuxeo-platform-tag</artifact>
              <artifact>org.nuxeo.ecm.platform:nuxeo-platform-webapp-types</artifact>
              <artifact>org.nuxeo.ecm.platform:nuxeo-search-core</artifact>
              <!-- no occurrences in java code but transitive dependencies of a test-jar -->
              <artifact>org.nuxeo.ecm.automation:nuxeo-automation-core</artifact>
            </ignoredUnusedDeclaredDependencies>
          </configuration>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>
