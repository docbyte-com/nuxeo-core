<?xml version="1.0"?>
<component name="org.nuxeo.ecm.platform.types.listeners">

  <extension target="org.nuxeo.ecm.core.event.EventServiceComponent"
    point="listener">

    <listener name="uiTypesLocalConfigurationListener" async="false"
      postCommit="false"
      class="org.nuxeo.ecm.platform.types.localconfiguration.UITypesConfigurationListener"
      priority="100">
      <event>beforeDocumentModification</event>
    </listener>

    <listener name="subtypeRestrictionListener" async="false"
              postCommit="false"
              class="org.nuxeo.ecm.platform.types.listener.SubtypeRestrictionListener"
              enabled="${nuxeo.subtype.restriction.enabled:=false}"
              priority="50">
      <event>aboutToCopy</event>
      <event>aboutToCreate</event>
      <event>aboutToMove</event>
    </listener>

  </extension>

</component>
