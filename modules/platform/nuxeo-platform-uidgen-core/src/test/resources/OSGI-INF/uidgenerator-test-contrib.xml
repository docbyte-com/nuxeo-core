<?xml version="1.0"?>
<component name="org.nuxeo.ecm.platform.uidgen.testGenerators">

  <extension target="org.nuxeo.runtime.datasource" point="datasources">
    <datasource name="jdbc/nxuidsequencer" driverClassName="${nuxeo.test.vcs.driver}"
        maxTotal="20" minTotal="5">
      <property name="url">${nuxeo.test.vcs.url}</property>
      <property name="username">${nuxeo.test.vcs.user}</property>
      <property name="password">${nuxeo.test.vcs.password}</property>
    </datasource>
  </extension>

  <extension target="org.nuxeo.ecm.core.persistence.PersistenceComponent" point="hibernate">
    <hibernateConfiguration name="NXUIDSequencer">
      <datasource>nxuidsequencer</datasource>
      <properties>
        <property name="hibernate.hbm2ddl.auto">update</property>
      </properties>
    </hibernateConfiguration>
  </extension>

  <extension target="org.nuxeo.ecm.core.uidgen.UIDGeneratorService" point="sequencers">
    <sequencer name="default" class="org.nuxeo.ecm.platform.uidgen.JPAUIDSequencerImpl" />
  </extension>

</component>
