<?xml version="1.0"?>
<component name="org.nuxeo.ecm.platform.rendering.fm.FreemarkerComponent">
  <implementation
          class="org.nuxeo.ecm.platform.rendering.fm.FreemarkerComponent" />
  <documentation>
    @author Bogdan Stefanescu (bs@nuxeo.com)
    Manage templates
  </documentation>

  <service>
    <provide interface="org.nuxeo.ecm.platform.rendering.fm.FreemarkerComponent" />
  </service>

  <extension-point name="settings">
    <documentation>
      Extension point to define the settings applied to freemarker.

      Example:
      <code>
        <setting name="output_encoding" value="UTF-8" />
      </code>
    </documentation>
    <object class="org.nuxeo.ecm.platform.rendering.fm.FreemarkerSettingDescriptor" />
  </extension-point>

</component>
