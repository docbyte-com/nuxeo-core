<?xml version="1.0" encoding="UTF-8"?>
<component name="org.nuxeo.user.preferences.impl.docModel">

  <documentation>
    User Preferences service implementation based on Directory.
    @since 2025.16
  </documentation>

  <service>
    <provide interface="org.nuxeo.user.preferences.api.UserPreferencesService" />
  </service>

  <implementation class="org.nuxeo.user.preferences.directory.UserPreferencesServiceImpl" />

  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="schema">
    <schema name="user_preferences" src="schemas/user-preferences.xsd" />
    <property schema="user_preferences" name="repository" indexOrder="ascending" />
    <property schema="user_preferences" name="key" indexOrder="ascending" />
    <property schema="user_preferences" name="docId" indexOrder="ascending" />
    <property schema="user_preferences" name="userId" indexOrder="ascending" />
  </extension>

  <extension target="org.nuxeo.ecm.directory.GenericDirectory" point="directories">
    <directory name="userPreferences" extends="template-directory">
      <schema>user_preferences</schema>
      <idField>id</idField>
      <autoincrementIdField>true</autoincrementIdField>
      <types>
        <type>system</type>
      </types>
      <permissions>
        <permission name="Read">
          <group>__Nobody__</group>
        </permission>
      </permissions>
    </directory>
  </extension>

</component>

