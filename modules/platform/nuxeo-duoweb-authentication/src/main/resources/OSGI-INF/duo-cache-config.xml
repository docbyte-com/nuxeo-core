<?xml version="1.0"?>
<component name="org.nuxeo.duo.factors.cache">

  <extension target="org.nuxeo.ecm.core.cache.CacheService" point="caches">

    <cache name="duo-state-cache">
      <!-- DuoWeb timeout is 1 minute => taking 4 minutes in case -->
      <ttl>4</ttl>
      <option name="maxSize">1000</option>
      <option name="concurrencyLevel=">10</option>
    </cache>

  </extension>

</component>
