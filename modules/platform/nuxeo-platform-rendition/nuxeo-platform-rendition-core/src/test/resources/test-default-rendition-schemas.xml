<?xml version="1.0" encoding="UTF-8"?>
<component name="org.nuxeo.dam.core.types">

  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="schema">
    <schema name="filederish" prefix="filederish" override="true" src="data/schemas/filederish.xsd"/>
  </extension>

  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="doctype">

    <doctype name="CustomFolderish" extends="File">
      <facet name="Folderish"/>
      <schema name="filederish"/>
      <schema name="common" />
      <schema name="dublincore" />
    </doctype>

    <doctype name="CustomRendition" extends="File">
      <schema name="filederish"/>
      <schema name="common" />
      <schema name="dublincore" />
    </doctype>

    <doctype name="CustomCollection" extends="Document">
      <facet name="Collection"/>
      <schema name="common" />
      <schema name="dublincore" />
    </doctype>

  </extension>

  <extension target="org.nuxeo.ecm.platform.rendition.service.RenditionService" point="targetDocTypes">
    <targetDocType from="CustomFolderish" to="CustomRendition"/>
  </extension>

  <extension target="org.nuxeo.ecm.core.lifecycle.LifeCycleService" point="lifecycle">

    <lifecycle name="custom" defaultInitial="draft">
      <transitions>
        <transition name="start" destinationState="started" />
      </transitions>
      <states>
        <state name="draft" initial="true">
          <transitions>
            <transition>start</transition>
          </transitions>
        </state>
        <state name="started" />
      </states>
    </lifecycle>

  </extension>

  <extension target="org.nuxeo.ecm.core.lifecycle.LifeCycleService"
    point="types">

    <types>
      <type name="CustomFolderish">custom</type>
      <type name="CustomRendition">custom</type>
    </types>

  </extension>

</component>
