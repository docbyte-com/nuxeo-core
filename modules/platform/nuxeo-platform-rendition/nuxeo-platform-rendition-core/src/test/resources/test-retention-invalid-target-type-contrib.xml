<?xml version="1.0" encoding="UTF-8"?>
<component name="org.nuxeo.ecm.platform.rendition.test.invalidTargetDocType">

  <require>org.nuxeo.dam.core.types</require>

  <extension target="org.nuxeo.ecm.core.schema.TypeService" point="doctype">
    <doctype name="CustomInvalidRendition">
      <schema name="filederish"/>
      <schema name="common" />
      <schema name="dublincore" />
    </doctype>
  </extension>

  <extension target="org.nuxeo.ecm.platform.rendition.service.RenditionService" point="targetDocTypes">
    <targetDocType from="CustomFolderish" to="CustomInvalidRendition"/>
  </extension>

  <extension target="org.nuxeo.ecm.core.lifecycle.LifeCycleService"
         point="types">
    <types>
      <type name="CustomInvalidRendition">custom</type>
    </types>
  </extension>

</component>
