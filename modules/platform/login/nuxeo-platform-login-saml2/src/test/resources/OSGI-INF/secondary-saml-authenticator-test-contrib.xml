<?xml version="1.0" encoding="UTF-8"?>
<component name="org.nuxeo.ecm.platform.auth.saml.secondary.authenticator.test">

  <extension target="org.nuxeo.ecm.platform.ui.web.auth.service.PluggableAuthenticationService" point="authenticators">
    <authenticationPlugin name="SAML_SECONDARY_AUTH" class="org.nuxeo.ecm.platform.auth.saml.SAMLAuthenticationProvider">
      <loginModulePlugin>Trusting_LM</loginModulePlugin>
      <needStartingURLSaving>true</needStartingURLSaving>
      <parameters>
        <!-- Required parameters -->
        <parameter name="metadata">${nuxeo.test.saml.secondary.authenticator.metadata}</parameter>
        <!-- Secondary SP parameters (optional for default case) -->
        <parameter name="entityId">${nuxeo.test.saml.secondary.entity.id}</parameter>
        <parameter name="authnRequestsSigned">true</parameter>
        <parameter name="wantAssertionsSigned">true</parameter>
        <parameter name="skewTime">5m</parameter>
        <!-- Login from configuration -->
        <parameter name="name">SAML Secondary Test</parameter>
      </parameters>
    </authenticationPlugin>
  </extension>

</component>
