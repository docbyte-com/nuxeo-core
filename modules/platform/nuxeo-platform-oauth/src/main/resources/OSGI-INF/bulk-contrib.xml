<?xml version="1.0"?>
<component name="org.nuxeo.ecm.platform.oauth.bulk.config" version="1.0.0">

  <require>org.nuxeo.ecm.core.bulk</require>

  <extension target="org.nuxeo.ecm.core.bulk" point="actions">
    <action name="garbageCollectExpiredOAuth2Tokens"
            validationClass="org.nuxeo.ecm.platform.oauth2.bulk.validation.GarbageCollectExpiredOAuth2TokensValidation"
            inputStream="bulk/garbageCollectExpiredOAuth2Tokens" bucketSize="500" batchSize="50" />
  </extension>

  <extension target="org.nuxeo.runtime.stream.service" point="streamProcessor">
    <streamProcessor name="garbageCollectExpiredOAuth2Tokens"
                     class="org.nuxeo.ecm.platform.oauth2.bulk.GarbageCollectExpiredOAuth2TokensAction"
                     defaultConcurrency="${nuxeo.bulk.action.garbageCollectExpiredOAuth2Tokens.defaultConcurrency:=2}"
                     defaultPartitions="${nuxeo.bulk.action.garbageCollectExpiredOAuth2Tokens.defaultPartitions:=4}">
      <policy name="default" maxRetries="3" delay="500ms" maxDelay="10s" continueOnFailure="false" />
    </streamProcessor>
  </extension>

</component>
