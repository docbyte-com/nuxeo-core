<?xml version="1.0"?>
<component name="org.nuxeo.ecm.core.notification.email.test">

  <extension
    target="org.nuxeo.ecm.platform.ec.notification.service.NotificationService"
    point="notifications">

    <notification name="DummyNotificationWithSubject" channel="email" availableIn="*"
                  subject="Notification on the document '${docTitle}'"
                  autoSubscribed="false"
                  template="dummyNotificationToSendMail">
      <event name="dummyNotificationWithSubject" />
    </notification>

    <notification name="DummyNotificationWithSubjectTemplate" channel="email" availableIn="*"
                  subjectTemplate="dummySubjectTemplate"
                  autoSubscribed="false"
                  template="dummyNotificationToSendMail">
      <event name="dummyNotificationWithSubjectTemplate" />
    </notification>

  </extension>

  <extension
    target="org.nuxeo.ecm.platform.ec.notification.service.NotificationService"
    point="templates">
    <template name="dummyNotificationToSendMail" src="templates/dummyNotificationMail.ftl" />
    <template name="dummySubjectTemplate" src="templates/dummySubjectTemplate.ftl" />
  </extension>

</component>
