## DO NOT EDIT THIS FILE, USE nuxeo.conf  ##
mongodb-audit.target=.

nuxeo.template.includes=mongodb
# used to be aware of the mongodb-audit template activation, for instance in blacklist.nxftl
nuxeo.mongodb.audit.enabled=true

nuxeo.uidsequencer.default.class=org.nuxeo.ecm.core.mongodb.seqgen.MongoDBUIDSequencer
